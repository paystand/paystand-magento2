<?php
/**
 * @var \Magento\Framework\View\Element\Template $block
 * @var \Hyva\Theme\ViewModel\Checkout\PaymentMethod $viewModel
 */

$viewModel = $block->getData('view_model');
$method = $block->getData('method');
$methodCode = $method->getCode();
$escaper = $block->getData('escaper') ?? $block;
$logoUrl = $block->getViewFileUrl('PayStand_PayStandMagento/images/logo_paystand_small.png');
?>

<div class="payment-method paystand-payment-method">
    <div class="payment-method-title field choice flex items-center">
        <input type="radio"
               name="payment[method]"
               class="radio"
               id="payment_method_<?= $escaper->escapeHtmlAttr($methodCode) ?>"
               value="<?= $escaper->escapeHtmlAttr($methodCode) ?>" />
        <label for="payment_method_<?= $escaper->escapeHtmlAttr($methodCode) ?>" class="label flex items-center ml-2 cursor-pointer">
            <img src="<?= $escaper->escapeUrl($logoUrl) ?>" alt="PayStand" style="height: 20px;"/>
        </label>
    </div>
    <div class="payment-method-content hidden">
        <!-- Button will be injected by JavaScript -->
    </div>
</div>
